# ─────────────────────────────────────────────────────────────
#  ServTrack — Environment Variables
#  Copy this to .env and fill in your Supabase values
# ─────────────────────────────────────────────────────────────

# ── Supabase Database ─────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string → URI
# Use Session mode (port 5432), NOT Transaction mode (port 6543)
DATABASE_URL=postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── JWT ───────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_your_secret_key_minimum_32_characters
# Generate: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email OTP / invites
MAIL_FROM=no-reply@servtrack.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Exotel phone OTP
# Dashboard: Settings -> API. Mumbai cluster uses api.in.exotel.com, Singapore uses api.exotel.com.
SMS_PROVIDER=exotel
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SENDER_ID=
EXOTEL_SUBDOMAIN=api.in.exotel.com
# Required for Indian DLT-compliant production SMS unless configured in Exotel dashboard.
EXOTEL_DLT_ENTITY_ID=
EXOTEL_DLT_TEMPLATE_ID=
EXOTEL_SMS_TYPE=transactional
